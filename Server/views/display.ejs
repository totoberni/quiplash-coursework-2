<!doctype html>
<html lang="en">

<%- include('header'); -%>

<div id="display">
  <h2>Quiplash Game Display</h2>
  <div v-if="connected">
    <!-- Waiting Stage -->
    <div v-if="gameState.stage === 'waiting'">
      <p>Waiting for players to join...</p>
    </div>
    
    <!-- Prompts Stage -->
    <div v-if="gameState.stage === 'prompts'">
      <h3>Submit Prompts</h3>
      <ul>
        <li v-for="prompt in gameState.prompts">{{ prompt.text }}</li>
      </ul>
    </div>
    
    <!-- Answers Stage -->
    <div v-if="gameState.stage === 'answers'">
      <h3>Answers for Prompts</h3>
      <ul>
        <li v-for="answer in gameState.answers">{{ answer.text }}</li>
      </ul>
    </div>
    
    <!-- Voting Stage -->
    <div v-if="gameState.stage === 'voting'">
      <h3>Voting on Answers</h3>
      <ul>
        <li v-for="vote in gameState.votes">{{ vote.text }}</li>
      </ul>
    </div>
    
    <!-- Results Stage -->
    <div v-if="gameState.stage === 'results'">
      <h3>Voting Results</h3>
      <ul>
        <li v-for="result in gameState.results">{{ result.prompt }} - {{ result.votes }} votes</li>
      </ul>
    </div>
    
    <!-- Scores Stage -->
    <div v-if="gameState.stage === 'scores'">
      <h3>Current Scores</h3>
      <ul>
        <li v-for="player in gameState.players">{{ player.username }}: {{ player.score }}</li>
      </ul>
    </div>
    
    <!-- Game Over Stage -->
    <div v-if="gameState.stage === 'gameOver'">
      <h3>Final Scores</h3>
      <ul>
        <li v-for="player in gameState.players">{{ player.username }}: {{ player.score }}</li>
      </ul>
      <h4>Podium</h4>
      <div>
        <p>Gold: {{ gameState.podium.gold }}</p>
        <p>Silver: {{ gameState.podium.silver }}</p>
        <p>Bronze: {{ gameState.podium.bronze }}</p>
      </div>
    </div>
  </div>
  <div v-else>
    <p>Connecting...</p>
  </div>
</div>

<script src="/socket.io/socket.io.js"></script>
<script src="https://cdn.jsdelivr.net/npm/vue/dist/vue.js"></script>
<script src="/static/display.js"></script>

<%- include('footer'); -%>

</html>